{
  "manifest_version": 3,
  "name": "Voice Form Filler",
  "version": "1.0.0",

  "permissions": [
    "activeTab",
    "tabs",
    "sidePanel"
  ],

  "host_permissions": ["<all_urls>"],

  "action": {
    "default_title": "Voice Form Filler"
  },

  "side_panel": {
    "default_path": "index.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["permission.html"],
      "matches": ["<all_urls>"]
    }
  ]
}